rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /guestbook/{entryId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'message', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.message is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 1000;
      allow update, delete: if request.auth != null;
    }

    match /mailingList/{emailId} {
      allow read: if request.auth != null;
      allow create, update: if request.resource.data.keys().hasAll(['email', 'source', 'subscribedAt'])
        && request.resource.data.email is string
        && request.resource.data.email.matches('.*@.*\\..*')
        && request.resource.data.email.size() <= 254;
      allow delete: if request.auth != null;
    }

    match /mediumPosts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
