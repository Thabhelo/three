rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email.lower() in [
          'thabheloduve@gmail.com',
          'thabhelo.duve@talladega.edu',
          'thabhelo@deepubuntu.com'
        ];
    }

    match /guestbook/{entryId} {
      allow read: if isAdmin();
      allow create: if request.resource.data.keys().hasAll(['name', 'message', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.message is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 1000
        && (!('website' in request.resource.data)
          || (request.resource.data.website is string && request.resource.data.website.size() <= 2048));
      allow update, delete: if isAdmin();
    }

    match /mailingList/{emailId} {
      allow read: if isAdmin();
      allow create, update: if request.resource.data.keys().hasAll(['email', 'source', 'subscribedAt'])
        && request.resource.data.email is string
        && request.resource.data.email.matches('.*@.*\\..*')
        && request.resource.data.email.size() <= 254;
      allow delete: if isAdmin();
    }

    match /mediumPosts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contactMessages/{messageId} {
      allow read: if isAdmin();
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'message', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.message is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.email.matches('.*@.*\\..*')
        && request.resource.data.email.size() <= 254
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 4000;
      allow update, delete: if isAdmin();
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow create, update: if isAdmin() && (
        imageId == '_meta'
          && request.resource.data.keys().hasAll(['seeded'])
          && request.resource.data.seeded is bool
        || imageId != '_meta'
          && request.resource.data.keys().hasAll(['src', 'label', 'order'])
          && request.resource.data.src is string
          && request.resource.data.label is string
          && request.resource.data.order is number
          && request.resource.data.label.size() > 0
          && request.resource.data.label.size() <= 120
          && request.resource.data.src.size() > 0
          && request.resource.data.src.size() <= 2048
      );
      allow delete: if isAdmin();
    }
  }
}
