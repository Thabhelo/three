# Contact: messages deliver to this inbox
VITE_CONTACT_RECIPIENT_EMAIL=thabheloduve@gmail.com

# Google Calendar appointment page (Book a Call tab)
VITE_BOOKING_URL=https://calendar.app.google/fB6AtdB5FVSs8YoA9

# Optional EmailJS (if set, used before FormSubmit fallback)
# Template should include: {{from_name}}, {{from_email}}, {{reply_to}}, {{message}}, {{to_email}}
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# Firebase (blog storage + admin auth)
# Project: thabhelo-portfolio (https://console.firebase.google.com/project/thabhelo-portfolio)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=thabhelo-portfolio.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=thabhelo-portfolio
VITE_FIREBASE_STORAGE_BUCKET=thabhelo-portfolio.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Blog admin (created by npm run firebase:seed after Auth is enabled)
BLOG_ADMIN_EMAIL=your_email@domain.com
BLOG_ADMIN_PASSWORD=your_secure_password

# Optional: used only by scripts/fetch-pexels-media.mjs (never expose as VITE_)
PEXELS_API_KEY=your_pexels_api_key
